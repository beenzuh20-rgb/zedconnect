# Neon PostgreSQL Database Connection (Required)
# Get your connection string from the Neon Console -> Connection Details -> Connection string (Prisma/PSQL)
DATABASE_URL=postgresql://username:password@ep-xxxx.us-east-2.aws.neon.tech/zedconnect?sslmode=require

# JWT Secret Key (Required - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your-secret-key-here

# JWT Token Expiry in minutes (Optional - Default: 10080 = 7 days)
# ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Cloudinary Configuration (Required - for profile picture uploads)
# Sign up for a free account at https://cloudinary.com to get your credentials
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
